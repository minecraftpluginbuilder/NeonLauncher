<?xml version="1.0" encoding="utf-8"?>
<!-- NeonLauncher: input field — dark with subtle border -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_6sdp" />
            <solid android:color="#12151F" />
            <stroke android:width="1dp" android:color="#1C1F2B" />
            <padding
                android:bottom="@dimen/padding_input_bottom"
                android:top="@dimen/padding_input_top" />
        </shape>
    </item>
    <item android:drawable="?attr/selectableItemBackground" />
</layer-list>
