<?xml version="1.0" encoding="utf-8"?>
<!-- NeonLauncher: version selector panel -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_8sdp" />
            <solid android:color="#1A00F0FF" />
            <stroke android:width="1dp" android:color="#00F0FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_8sdp" />
            <solid android:color="#11131A" />
            <stroke android:width="1dp" android:color="#2200F0FF" />
        </shape>
    </item>
</selector>
