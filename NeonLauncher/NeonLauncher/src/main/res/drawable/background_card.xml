<?xml version="1.0" encoding="utf-8"?>
<!-- NeonLauncher: dark card with subtle neon cyan border -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- neon cyan border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_8sdp" />
            <solid android:color="#1A00F0FF" />
            <stroke android:width="1dp" android:color="#2200F0FF" />
        </shape>
    </item>
    <!-- dark fill inset -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_8sdp" />
            <solid android:color="#0D0F1A" />
        </shape>
    </item>
</layer-list>
