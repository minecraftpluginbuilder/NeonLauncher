<?xml version="1.0" encoding="utf-8"?>
<!-- NeonLauncher: nav item selected — neon left accent bar -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- dark fill -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_6sdp" />
            <solid android:color="#161A28" />
        </shape>
    </item>
    <!-- left neon accent bar (3dp wide) -->
    <item android:right="0dp" android:top="0dp" android:bottom="0dp" android:left="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_6sdp" />
            <stroke android:width="2dp" android:color="#00F0FF" />
        </shape>
    </item>
</layer-list>
