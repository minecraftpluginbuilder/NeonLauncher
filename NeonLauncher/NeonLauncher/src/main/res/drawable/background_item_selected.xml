<?xml version="1.0" encoding="utf-8"?>
<!-- NeonLauncher: selected item — neon cyan border glow -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- neon glow outer border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_6sdp" />
            <solid android:color="#2600F0FF" />
            <stroke android:width="1dp" android:color="#00F0FF" />
        </shape>
    </item>
    <!-- dark fill inset -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_6sdp" />
            <solid android:color="#161A28" />
        </shape>
    </item>
</layer-list>
