<?xml version="1.0" encoding="utf-8"?>
<!--
    NeonLauncher — Dark Neon Cyan theme (Lunar Client-inspired)
    Accent:  #00F0FF  (neon cyan)
    Base:    #0A0A0F  (deep near-black)
    Surface: #11131A  (card/panel surface)
    Muted:   #1C1F2B  (overlays, toolbar)
-->
<resources>
    <color name="black_or_white">#FFFFFF</color>

    <!-- Backgrounds -->
    <color name="background_app">#0A0A0F</color>
    <color name="background_app_error">#1A0A0F</color>
    <color name="background_overlay">#1C1F2B</color>
    <color name="background_status_bar">#080810</color>
    <color name="background_menu_top">#0D0F1A</color>
    <color name="background_menu_top_error">#2A0D14</color>
    <color name="background_menu_element">#00F0FF</color>
    <color name="background_ripple_effect">#3300F0FF</color>

    <!-- Buttons -->
    <color name="button_background">#1C1F2B</color>
    <color name="button_background_selected">#252838</color>
    <color name="dialog_background">#11131A</color>

    <!-- Menu / nav bar -->
    <color name="menu_bar">#0D0F1A</color>
    <color name="menu_bar_text">#E0FEFF</color>
    <color name="menu_overlay">#CC0A0A0F</color>
    <color name="menu_progress">#00F0FF</color>

    <!-- List items -->
    <color name="background_item">#CC11131A</color>
    <color name="background_item_selected">#CC1C2030</color>
    <color name="background_item_disabled">#CC1A1014</color>
    <color name="background_sponsor_intermediate">#CC1A1F10</color>
    <color name="background_sponsor_advanced">#CC1A1410</color>

    <!-- Edit / input fields -->
    <color name="edit_box_fill">#15181F</color>
    <color name="edit_box_fill_selected">#1A1D28</color>

    <!-- Misc -->
    <color name="mod_category_fill">#4400F0FF</color>
    <color name="text_background_fill">#991C1F2B</color>

    <color name="settings_category">#00F0FF</color>

    <color name="favorite_color">#FF4C8B</color>

    <color name="icon_color">#E0FEFF</color>

    <color name="primary_text">#E8F0FF</color>
</resources>