<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- NeonLauncher — night qualifier (identical to default; always dark) -->
    <style name="AppTheme" parent="@style/Theme.AppCompat.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@color/background_status_bar</item>
        <item name="android:navigationBarColor">@color/background_app</item>
        <item name="android:scrollbarThumbHorizontal">@color/background_menu_element</item>
        <item name="android:scrollbarThumbVertical">@color/background_menu_element</item>
        <item name="android:textSize">@dimen/_12ssp</item>
        <item name="android:windowBackground">@color/background_app</item>
        <item name="colorPrimary">@color/background_menu_element</item>
        <item name="colorAccent">@color/background_menu_element</item>
        <item name="android:textColorPrimary">@color/primary_text</item>
        <item name="android:textColorSecondary">#8800F0FF</item>
        <item name="android:textColorHint">#44E0FEFF</item>
        <item name="android:colorControlActivated">#00F0FF</item>
        <item name="android:colorControlHighlight">#2200F0FF</item>
        <item name="radioButtonStyle">@style/GlitchRadioButton</item>
        <item name="checkboxStyle">@style/GlitchCheckBox</item>
    </style>

    <style name="GlitchRadioButton" parent="Widget.AppCompat.CompoundButton.RadioButton">
        <item name="buttonTint">#00F0FF</item>
    </style>

    <style name="GlitchCheckBox" parent="Widget.AppCompat.CompoundButton.CheckBox">
        <item name="buttonTint">#00F0FF</item>
    </style>

    <style name="CustomDialogStyle" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="android:scrollbarThumbHorizontal">@color/background_menu_element</item>
        <item name="android:scrollbarThumbVertical">@color/background_menu_element</item>
    </style>

    <style name="CustomAlertDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="android:scrollbarThumbHorizontal">@color/background_menu_element</item>
        <item name="android:scrollbarThumbVertical">@color/background_menu_element</item>
    </style>
</resources>
