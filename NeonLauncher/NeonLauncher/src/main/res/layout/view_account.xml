<?xml version="1.0" encoding="utf-8"?>
<!--
    NeonLauncher — view_account.xml
    Centered account display: avatar → username → account type badge
-->
<com.neonlauncher.app.ui.layout.AnimConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/_14sdp"
    android:background="?android:attr/selectableItemBackgroundBorderless">

    <!-- Avatar ring: neon cyan border around the avatar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/avatar_card"
        android:layout_width="@dimen/_60sdp"
        android:layout_height="@dimen/_60sdp"
        app:cardCornerRadius="@dimen/_30sdp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#1A00F0FF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/user_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_help"
            tools:ignore="ContentDescription" />

    </androidx.cardview.widget.CardView>

    <!-- Username -->
    <TextView
        android:id="@+id/user_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_8sdp"
        android:textColor="@color/primary_text"
        android:textSize="@dimen/_14ssp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/avatar_card"
        tools:text="Steve" />

    <!-- Account type badge -->
    <TextView
        android:id="@+id/account_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_4sdp"
        android:paddingHorizontal="@dimen/_8sdp"
        android:paddingVertical="@dimen/_2sdp"
        android:textColor="#00F0FF"
        android:textSize="@dimen/_10ssp"
        android:background="@drawable/background_item_selected"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/user_name"
        tools:text="Microsoft" />

</com.neonlauncher.app.ui.layout.AnimConstraintLayout>