<?xml version="1.0" encoding="utf-8"?>
<!--
    NeonLauncher — fragment_launcher.xml
    Lunar Client-style layout:
      LEFT  (weight 6.5): dark sidebar with nav items
      RIGHT (weight 3):   account + version + PLAY
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_menu_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    tools:ignore="ContentDescription">

    <!-- ═══════════════ LEFT SIDEBAR ═══════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/launcher_menu"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/play_layout"
        app:layout_constraintHorizontal_weight="6.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- thin neon separator on right edge of sidebar -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@drawable/neon_divider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="@dimen/_8sdp"
                android:paddingBottom="@dimen/_8sdp">

                <!-- ── ABOUT ── -->
                <com.neonlauncher.app.ui.layout.AnimRelativeLayout
                    android:id="@+id/about_button"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_44sdp"
                    android:layout_marginTop="@dimen/_6sdp"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:background="@drawable/background_item"
                    android:paddingHorizontal="@dimen/_10sdp"
                    android:translationZ="2dp"
                    app:ripple_for_relative="true">

                    <ImageView
                        android:id="@+id/about_icon"
                        android:layout_width="@dimen/_22sdp"
                        android:layout_height="@dimen/_22sdp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/_4sdp"
                        android:src="@drawable/ic_about"
                        app:tint="#00F0FF" />

                    <TextView
                        android:id="@+id/about_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/_12sdp"
                        android:layout_marginEnd="@dimen/_4sdp"
                        android:layout_toEndOf="@id/about_icon"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_12sdp" />

                </com.neonlauncher.app.ui.layout.AnimRelativeLayout>

                <!-- ── CUSTOM CONTROLS ── -->
                <com.neonlauncher.app.ui.layout.AnimRelativeLayout
                    android:id="@+id/custom_control_button"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_44sdp"
                    android:layout_marginTop="@dimen/_6sdp"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:background="@drawable/background_item"
                    android:paddingHorizontal="@dimen/_10sdp"
                    android:translationZ="2dp"
                    app:ripple_for_relative="true">

                    <ImageView
                        android:id="@+id/custom_control_icon"
                        android:layout_width="@dimen/_22sdp"
                        android:layout_height="@dimen/_22sdp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/_4sdp"
                        android:src="@drawable/ic_menu_custom_controls"
                        app:tint="#00F0FF" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/_12sdp"
                        android:layout_marginEnd="@dimen/_4sdp"
                        android:layout_toEndOf="@id/custom_control_icon"
                        android:text="@string/custom_control_title"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_12sdp" />

                </com.neonlauncher.app.ui.layout.AnimRelativeLayout>

                <!-- ── OPEN DIR ── -->
                <com.neonlauncher.app.ui.layout.AnimRelativeLayout
                    android:id="@+id/open_main_dir_button"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_44sdp"
                    android:layout_marginTop="@dimen/_6sdp"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:background="@drawable/background_item"
                    android:paddingHorizontal="@dimen/_10sdp"
                    android:translationZ="2dp"
                    app:ripple_for_relative="true">

                    <ImageView
                        android:id="@+id/open_main_dir_icon"
                        android:layout_width="@dimen/_22sdp"
                        android:layout_height="@dimen/_22sdp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/_4sdp"
                        android:src="@drawable/ic_folder"
                        app:tint="#00F0FF" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/_12sdp"
                        android:layout_marginEnd="@dimen/_4sdp"
                        android:layout_toEndOf="@id/open_main_dir_icon"
                        android:text="@string/main_open_main_dir"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_12sdp" />

                </com.neonlauncher.app.ui.layout.AnimRelativeLayout>

                <!-- ── INSTALL JAR ── -->
                <com.neonlauncher.app.ui.layout.AnimRelativeLayout
                    android:id="@+id/install_jar_button"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_44sdp"
                    android:layout_marginTop="@dimen/_6sdp"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:background="@drawable/background_item"
                    android:paddingHorizontal="@dimen/_10sdp"
                    android:translationZ="2dp"
                    app:ripple_for_relative="true">

                    <ImageView
                        android:id="@+id/install_jar_icon"
                        android:layout_width="@dimen/_22sdp"
                        android:layout_height="@dimen/_22sdp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/_4sdp"
                        android:src="@drawable/ic_java"
                        app:tint="#00F0FF" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/_12sdp"
                        android:layout_marginEnd="@dimen/_4sdp"
                        android:layout_toEndOf="@id/install_jar_icon"
                        android:text="@string/main_install_jar_file"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_12sdp" />

                </com.neonlauncher.app.ui.layout.AnimRelativeLayout>

                <!-- ── SHARE LOGS ── -->
                <com.neonlauncher.app.ui.layout.AnimRelativeLayout
                    android:id="@+id/share_logs_button"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_44sdp"
                    android:layout_marginTop="@dimen/_6sdp"
                    android:layout_marginBottom="@dimen/_6sdp"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:background="@drawable/background_item"
                    android:paddingHorizontal="@dimen/_10sdp"
                    android:translationZ="2dp"
                    app:ripple_for_relative="true">

                    <ImageView
                        android:id="@+id/share_logs_icon"
                        android:layout_width="@dimen/_22sdp"
                        android:layout_height="@dimen/_22sdp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/_4sdp"
                        android:src="@drawable/ic_share"
                        app:tint="#00F0FF" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/_12sdp"
                        android:layout_marginEnd="@dimen/_4sdp"
                        android:layout_toEndOf="@id/share_logs_icon"
                        android:text="@string/main_share_logs"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_12sdp" />

                </com.neonlauncher.app.ui.layout.AnimRelativeLayout>

            </LinearLayout>
        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
