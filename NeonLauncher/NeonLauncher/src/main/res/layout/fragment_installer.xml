<?xml version="1.0" encoding="utf-8"?>
<!--
    NeonLauncher — fragment_installer.xml
    Lunar Client-style content installer:
    Tabs: Mods | Modpacks | Resource Packs | Shaders | Worlds
    LEFT: search + filter + result list
    RIGHT: selected item detail + Download button
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <!-- ── Category tabs row ── -->
    <HorizontalScrollView
        android:id="@+id/installer_tabs_scroll"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_36sdp"
        android:scrollbars="none"
        android:background="#0D0F1A"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/installer_tabs"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/_8sdp"
            android:gravity="center_vertical">

            <!-- MODS tab -->
            <TextView
                android:id="@+id/tab_mods"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingHorizontal="@dimen/_14sdp"
                android:text="@string/installer_mods"
                android:textColor="#00F0FF"
                android:textSize="@dimen/_12ssp"
                android:textStyle="bold"
                android:background="@drawable/background_nav_selected" />

            <!-- MODPACKS tab -->
            <TextView
                android:id="@+id/tab_modpacks"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/_4sdp"
                android:gravity="center"
                android:paddingHorizontal="@dimen/_14sdp"
                android:text="@string/installer_modpacks"
                android:textColor="#99E0FEFF"
                android:textSize="@dimen/_12ssp"
                android:background="?android:attr/selectableItemBackground" />

            <!-- RESOURCE PACKS tab -->
            <TextView
                android:id="@+id/tab_resource_packs"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/_4sdp"
                android:gravity="center"
                android:paddingHorizontal="@dimen/_14sdp"
                android:text="@string/installer_resource_packs"
                android:textColor="#99E0FEFF"
                android:textSize="@dimen/_12ssp"
                android:background="?android:attr/selectableItemBackground" />

            <!-- SHADERS tab -->
            <TextView
                android:id="@+id/tab_shaders"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/_4sdp"
                android:gravity="center"
                android:paddingHorizontal="@dimen/_14sdp"
                android:text="@string/installer_shaders"
                android:textColor="#99E0FEFF"
                android:textSize="@dimen/_12ssp"
                android:background="?android:attr/selectableItemBackground" />

            <!-- WORLDS tab -->
            <TextView
                android:id="@+id/tab_worlds"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/_4sdp"
                android:gravity="center"
                android:paddingHorizontal="@dimen/_14sdp"
                android:text="@string/installer_worlds"
                android:textColor="#99E0FEFF"
                android:textSize="@dimen/_12ssp"
                android:background="?android:attr/selectableItemBackground" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Neon divider under tabs -->
    <View
        android:id="@+id/tab_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@drawable/neon_divider"
        app:layout_constraintTop_toBottomOf="@id/installer_tabs_scroll" />

    <!-- ── BODY: split LEFT list + RIGHT detail ── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tab_divider">

        <!-- ── LEFT PANEL: search + list ── -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/installer_list_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintEnd_toStartOf="@+id/installer_detail_panel"
            app:layout_constraintHorizontal_weight="6.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Search bar -->
            <com.neonlauncher.app.ui.view.AnimEditText
                android:id="@+id/installer_search"
                android:layout_width="0dp"
                android:layout_height="@dimen/_36sdp"
                android:layout_marginHorizontal="@dimen/_10sdp"
                android:layout_marginTop="@dimen/_10sdp"
                android:background="@drawable/background_edit_box"
                android:hint="@string/installer_search_hint"
                android:inputType="text"
                android:paddingHorizontal="@dimen/_10sdp"
                android:textColor="@color/primary_text"
                android:textColorHint="#44E0FEFF"
                android:imeOptions="actionSearch"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Filter chips row -->
            <HorizontalScrollView
                android:id="@+id/installer_filters_scroll"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_32sdp"
                android:layout_marginTop="@dimen/_6sdp"
                android:scrollbars="none"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/installer_search">

                <LinearLayout
                    android:id="@+id/installer_filters"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/_10sdp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/filter_featured"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/_24sdp"
                        android:gravity="center"
                        android:paddingHorizontal="@dimen/_10sdp"
                        android:text="@string/installer_featured"
                        android:textColor="#00F0FF"
                        android:textSize="@dimen/_10ssp"
                        android:background="@drawable/background_item_selected" />

                    <TextView
                        android:id="@+id/filter_installed"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/_24sdp"
                        android:layout_marginStart="@dimen/_6sdp"
                        android:gravity="center"
                        android:paddingHorizontal="@dimen/_10sdp"
                        android:text="@string/installer_installed"
                        android:textColor="#99E0FEFF"
                        android:textSize="@dimen/_10ssp"
                        android:background="@drawable/background_item_unselected" />

                </LinearLayout>

            </HorizontalScrollView>

            <!-- Content list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/installer_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginHorizontal="@dimen/_8sdp"
                android:layout_marginBottom="@dimen/_8sdp"
                android:paddingVertical="@dimen/_4sdp"
                android:clipToPadding="false"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/installer_filters_scroll" />

            <!-- Loading spinner -->
            <ProgressBar
                android:id="@+id/installer_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminateTint="#00F0FF"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Neon separator -->
        <View
            android:id="@+id/installer_separator"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@drawable/neon_divider"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/installer_detail_panel"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- ── RIGHT PANEL: item detail + download ── -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/installer_detail_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="#CC0A0A0F"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="3"
            app:layout_constraintStart_toEndOf="@+id/installer_list_panel"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Placeholder when nothing selected -->
            <LinearLayout
                android:id="@+id/installer_empty_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_40sdp"
                    android:src="@drawable/ic_download"
                    android:alpha="0.3"
                    app:tint="#00F0FF"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_8sdp"
                    android:text="Select an item"
                    android:textColor="#3300F0FF"
                    android:textSize="@dimen/_11ssp"
                    tools:ignore="HardcodedText" />

            </LinearLayout>

            <!-- Item detail (shown when something is selected) -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/installer_detail_scroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintBottom_toTopOf="@+id/installer_download_button"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/_12sdp">

                    <!-- Item icon -->
                    <ImageView
                        android:id="@+id/detail_icon"
                        android:layout_width="@dimen/_56sdp"
                        android:layout_height="@dimen/_56sdp"
                        android:layout_gravity="center_horizontal"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_download"
                        tools:ignore="ContentDescription" />

                    <!-- Item name -->
                    <TextView
                        android:id="@+id/detail_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_8sdp"
                        android:gravity="center"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_14ssp"
                        android:textStyle="bold"
                        tools:text="Sodium" />

                    <!-- Author + downloads -->
                    <TextView
                        android:id="@+id/detail_author"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_2sdp"
                        android:gravity="center"
                        android:textColor="#5500F0FF"
                        android:textSize="@dimen/_10ssp"
                        tools:text="by jellysquid3 • 12M downloads" />

                    <!-- Neon divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/_10sdp"
                        android:background="@drawable/neon_divider" />

                    <!-- Description -->
                    <TextView
                        android:id="@+id/detail_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_11ssp"
                        android:lineSpacingExtra="2dp"
                        tools:text="A Fabric mod that optimizes the Minecraft client to provide better performance." />

                    <!-- Version selector -->
                    <TextView
                        android:id="@+id/detail_version_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:textColor="#00F0FF"
                        android:textSize="@dimen/_11ssp"
                        android:textStyle="bold"
                        android:text="Select Version" 
                        tools:ignore="HardcodedText"/>

                    <Spinner
                        android:id="@+id/detail_version_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_32sdp"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/background_version_selector"
                        android:paddingHorizontal="@dimen/_8sdp" />

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>

            <!-- DOWNLOAD button -->
            <com.neonlauncher.app.ui.view.AnimButton
                android:id="@+id/installer_download_button"
                android:layout_width="0dp"
                android:layout_height="@dimen/_40sdp"
                android:layout_marginHorizontal="@dimen/_8sdp"
                android:layout_marginBottom="@dimen/_10sdp"
                android:background="@drawable/background_play_button"
                android:text="@string/installer_download"
                android:textAllCaps="true"
                android:textColor="#0A0A0F"
                android:textStyle="bold"
                android:elevation="4dp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
