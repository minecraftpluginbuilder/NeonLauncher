<?xml version="1.0" encoding="utf-8"?>
<!--
    NeonLauncher — fragment_about_info_page.xml
    Clean About page: logo → description → links → open-source credits
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="@dimen/_12sdp"
            android:paddingHorizontal="@dimen/_12sdp">

            <!-- ── Hero card: icon + wordmark + description ── -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_card"
                android:padding="@dimen/_16sdp">

                <!-- App icon -->
                <ImageView
                    android:id="@+id/about_icon"
                    android:layout_width="@dimen/_56sdp"
                    android:layout_height="@dimen/_56sdp"
                    android:scaleType="fitCenter"
                    android:src="@mipmap/ic_launcher_icon_neon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:ignore="ContentDescription" />

                <!-- GLITCHLAUNCHER wordmark -->
                <ImageView
                    android:id="@+id/title"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_26sdp"
                    android:layout_marginStart="@dimen/_12sdp"
                    android:scaleType="fitStart"
                    android:src="@drawable/app_name_title"
                    app:layout_constraintBottom_toTopOf="@+id/version_text"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/about_icon"
                    app:layout_constraintTop_toTopOf="@id/about_icon"
                    app:layout_constraintVertical_chainStyle="packed"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:id="@+id/version_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_12sdp"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:textColor="#5500F0FF"
                    android:textSize="@dimen/_10ssp"
                    app:layout_constraintBottom_toBottomOf="@id/about_icon"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/about_icon"
                    app:layout_constraintTop_toBottomOf="@id/title"
                    tools:text="v1.4.3.03 • GPL v3" />

                <!-- Neon divider -->
                <View
                    android:id="@+id/divider1"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="@dimen/_12sdp"
                    android:background="@drawable/neon_divider"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/about_icon" />

                <TextView
                    android:id="@+id/dec1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/_12ssp"
                    android:lineSpacingExtra="2dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider1" />

                <TextView
                    android:id="@+id/dec2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_8sdp"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/_12ssp"
                    android:lineSpacingExtra="2dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/dec1" />

                <TextView
                    android:id="@+id/dec3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_8sdp"
                    android:textColor="#7700F0FF"
                    android:textSize="@dimen/_11ssp"
                    android:lineSpacingExtra="2dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/dec2" />

                <!-- Buttons row -->
                <LinearLayout
                    android:id="@+id/buttons_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_12sdp"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/dec3">

                    <com.neonlauncher.app.ui.view.AnimButton
                        android:id="@+id/github_button"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_34sdp"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/_4sdp"
                        android:text="GitHub"
                        android:textColor="#0A0A0F"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />

                    <com.neonlauncher.app.ui.view.AnimButton
                        android:id="@+id/discord_button"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_34sdp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="@dimen/_4sdp"
                        android:text="Discord"
                        android:textColor="#0A0A0F"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />

                    <com.neonlauncher.app.ui.view.AnimButton
                        android:id="@+id/license_button"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_34sdp"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/_4sdp"
                        android:text="GPL v3"
                        android:textColor="#0A0A0F"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />

                    <!-- Hidden QQ button — kept for compatibility -->
                    <com.neonlauncher.app.ui.view.AnimButton
                        android:id="@+id/qq_group_button"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_34sdp"
                        android:layout_weight="1"
                        android:text="QQ"
                        android:visibility="gone"
                        tools:ignore="HardcodedText" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ── Open Source Credits card ── -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_12sdp"
                android:background="@drawable/background_card"
                android:padding="@dimen/_12sdp">

                <TextView
                    android:id="@+id/about_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/about_contributors"
                    android:textColor="#00F0FF"
                    android:textSize="@dimen/_13ssp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/divider2"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="@dimen/_8sdp"
                    android:background="@drawable/neon_divider"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/about_title" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/about_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_4sdp"
                    android:paddingVertical="@dimen/_4sdp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider2" />

                <com.neonlauncher.app.ui.view.AnimButton
                    android:id="@+id/sponsor"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_36sdp"
                    android:layout_marginTop="@dimen/_8sdp"
                    android:text="@string/about_sponsors_list"
                    android:textColor="#0A0A0F"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/about_recycler" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
